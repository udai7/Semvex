# Frontend (Next.js) environment — copy to .env.local for local overrides.

# Backend FastAPI origin the Next server proxies to (server-side only).
# Defaults to http://localhost:8000 if unset.
SEMVEX_API_URL=http://localhost:8000

# Public site origin, used to build absolute OpenGraph/Twitter image URLs so
# shared links render a proper thumbnail. Set this to your deployed domain in
# production (e.g. https://your-domain.com). Falls back to localhost in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Where to send users after login (the run script sets this to /search).
SEMVEX_POST_LOGIN_REDIRECT=/search
