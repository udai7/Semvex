# ============================================================================
# Semvex configuration. Copy to `.env` and adjust. Everything the app reads
# comes from here (loaded via python-dotenv at startup).
# ============================================================================

# --- Data layer (REQUIRED): PostgreSQL + pgvector ---------------------------
# The production source of truth. Users, accounts, analytics, and the product
# catalog + embeddings all live here.
DATABASE_URL=postgresql://semvex:semvex@localhost:5433/semvex
# Connection pool sizing
DB_POOL_MIN=1
DB_POOL_MAX=10

# --- Sessions / security (REQUIRED in prod) ---------------------------------
# 32+ byte random secret used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SEMVEX_SECRET=change-me-to-a-long-random-hex-string
SEMVEX_SESSION_TTL=604800          # 7 days, in seconds

# --- Admin ------------------------------------------------------------------
# Comma-separated emails allowed to view /admin analytics. If empty, any
# signed-in user can view it (demo convenience — lock this down in prod).
SEMVEX_ADMIN_EMAILS=

# --- Auth rate limiting -----------------------------------------------------
SEMVEX_AUTH_RATE_MAX=10             # attempts...
SEMVEX_AUTH_RATE_WINDOW=60          # ...per this many seconds, per IP

# --- Search -----------------------------------------------------------------
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
SEMVEX_TOP_K=8
SEMVEX_RERANK_CANDIDATES=30
SEMVEX_EMBED_DIM=384               # pgvector column dimension (bge-small = 384)

# --- Embedding provider -----------------------------------------------------
# auto|local|hf|hashing. "auto" = local sentence-transformers if installed,
# else HuggingFace Inference API if HF_API_TOKEN set, else hashing fallback.
# Pattern for a low-RAM VPS: embed the catalog locally (install
# requirements-ingest.txt → local bge-small), then run the server with
# provider=hf so live queries hit HF and no model sits in VPS RAM. Both are
# bge-small (384-d), so their vectors are interchangeable.
SEMVEX_EMBEDDING_PROVIDER=auto
HF_API_TOKEN=                      # https://huggingface.co/settings/tokens (free)
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Elasticsearch (optional BM25 keyword engine) ---------------------------
# Leave ELASTICSEARCH_URL blank to use Postgres full-text (tsvector) for
# keyword search. When set, ES serves BM25 and the app auto-falls back to
# tsvector if ES is unreachable. ES is a pure ranker; product data + vectors
# stay in Postgres.
ELASTICSEARCH_URL=                 # e.g. http://localhost:9200
ELASTICSEARCH_API_KEY=             # only for managed/secured clusters
ELASTICSEARCH_INDEX=semvex_products
SEMVEX_KEYWORD_ENGINE=auto         # auto|elasticsearch|tsvector

# --- Email: Gmail SMTP (for signup verification codes) ----------------------
# Generate a 16-char App Password at https://myaccount.google.com/apppasswords
# (requires 2FA enabled on the Google account). Leave SMTP_APP_PASSWORD blank to
# disable sending — the 6-digit code is then logged to the server console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465                       # 465 = SSL, 587 = STARTTLS
SMTP_USER=udaid347@gmail.com
SMTP_APP_PASSWORD=                  # paste your Gmail app password here
SMTP_FROM=Semvex <udaid347@gmail.com>
SEMVEX_EMAIL_CODE_TTL=600           # verification code lifetime, seconds
SEMVEX_EMAIL_CODE_MAX_ATTEMPTS=5    # wrong tries before a resend is required

# --- Google OAuth (OPTIONAL) ------------------------------------------------
# Leave blank to disable Google sign-in (email + password + 2FA still works).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SEMVEX_OAUTH_REDIRECT=http://localhost:3000/auth/google/callback
SEMVEX_POST_LOGIN_REDIRECT=/search
SEMVEX_LOGIN_ERROR_REDIRECT=/signin#error
